{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "azu",
  "version": "0.1.0",
  "identifier": "dev.azu.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "withGlobalTauri": false,
    "windows": [
      {
        "title": "Azu",
        "width": 1200,
        "height": 800,
        "minWidth": 600,
        "minHeight": 400,
        "decorations": false,
        "transparent": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": ["icons/icon.ico"],
    "windows": {
      "wix": {
        "language": "en-US"
      },
      "nsis": {
        "installMode": "currentUser",
        "languages": ["English"],
        "installerIcon": "icons/icon.ico",
        "headerImage": "icons/icon.ico",
        "createDesktopShortcut": false
      }
    },
    "shortDescription": "AI-Native Terminal",
    "longDescription": "Lightweight terminal for AI agents. Run Claude Code, Codex, and any CLI in a flexible grid with per-pane project context.",
    "copyright": "© 2026 Nico Arriola (nico.arriola@gmail.com)",
    "category": "DeveloperTool"
  }
}
